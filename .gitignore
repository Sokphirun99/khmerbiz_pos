# ═══════════════════════════════════════════════════════════════
# Flutter/Dart .gitignore
# ═══════════════════════════════════════════════════════════════

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.AppleDouble
.LSOverride
._*

# Documents
*.doc
*.docx
*.pdf
*.rtf

# Archives
*.zip
*.tar.gz
*.rar

# Temp files
*.tmp
*.temp
*.bak
*.orig
*.swp
*~

# Build directories
.build/
.buildlog/
build/
**/build/

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.qwen/
*.sublime-project
*.sublime-workspace

# Flutter/Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
**/ios/Flutter/.last_build_id

# Documentation
**/doc/api/

# Symbolication
app.*.symbols

# Obfuscation
app.*.map.json

# Android
/android/app/debug/
/android/app/profile/
/android/app/release/
/android/.gradle/
/android/captures/
/android/gradlew
/android/gradlew.bat
/android/local.properties
/android/**/android.iml
/android/**/.gradle/
/android/**/build/
/android/**/generated/
/android/app/google-services.json
/android/**/key.properties
/android/**/gradle-wrapper.jar

# iOS
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework/
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Debug.xcconfig
**/ios/Flutter/Release.xcconfig
**/ios/**/*.xcworkspace/
**/ios/**/*.xcodeproj/project.xcworkspace/
**/ios/**/*.xcodeproj/xcuserdata/
**/ios/Flutter/ephemeral/
**/ios/**/.generated/
**/ios/Runner/GeneratedPluginRegistrant.*

# macOS
**/macos/Pods/
**/macos/.symlinks/
**/macos/Flutter/ephemeral/
**/macos/**/.generated/

# Web
**/web/manifest.json
**/web/flutter_bootstrap.js
**/web/flutter_service_worker.js

# Environment variables (secrets!)
.env
.env.local
.env.*.local
.env.development
.env.production

# Coverage
coverage/
.lcov.info
test/.test_coverage.dart

# Swift PM
.swiftpm/
migrate_working_dir/

# Xcode
**/xcuserdata/
**/DerivedData/
**/XCBuildData/

# CocoaPods
**/Pods/
**/Podfile.lock
**/Manifest.lock

# Fastlane
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots/
**/fastlane/test_output/
**/fastlane/readme.md

# Firebase
**/firebase-app-id-file.json
**/google-services.json
**/GoogleService-Info.plist
lib/firebase_options.dart

# Keys and secrets
**/key.properties
**/keystore/
**/*.jks
**/*.keystore
**/*.p12
**/*.pfx

# Database
**/*.db
**/*.sqlite
**/*.realm

# Cache
**/cache/
**/.cache/
**/*.cache

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
analysis_output.txt
analysis_report.txt
final_analysis_report.txt
lint_report*.txt

